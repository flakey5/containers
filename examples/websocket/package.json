{
  "name": "containers-websocket-example",
  "version": "1.0.0",
  "description": "Integration test fixture for @cloudflare/containers (websocket)",
  "type": "module",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types",
    "predev": "npm --prefix ../.. run build && npm run cf-typegen",
    "dev": "wrangler dev",
    "predeploy": "npm --prefix ../.. run build && npm run cf-typegen",
    "deploy": "wrangler deploy",
    "pretypecheck": "npm --prefix ../.. run build && npm run cf-typegen",
    "typecheck": "tsc --noEmit",
    "pretest": "npm --prefix ../.. run build && npm run cf-typegen",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.102.0",
    "ws": "^8.20.1"
  },
  "dependencies": {
    "@cloudflare/containers": "file:../.."
  }
}
